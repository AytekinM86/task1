# Copy to `.env` and adjust for local runs. All vars are prefixed DATAGEN_ so
# they never clash with the repo's POSTGRES_* variables.

# --- Database connection ---------------------------------------------------
DATAGEN_DB_HOST=localhost
DATAGEN_DB_PORT=5432
DATAGEN_DB_NAME=liquibase_hospital
DATAGEN_DB_USER=postgres
DATAGEN_DB_PASSWORD=postgres

# --- Behaviour -------------------------------------------------------------
DATAGEN_LOG_LEVEL=INFO
DATAGEN_BATCH_SIZE=500

# Optional fixed seed for reproducible fake data (leave empty for random).
DATAGEN_FAKER_SEED=

# Temporal window (days) the generated data spans, ending "now".
DATAGEN_WINDOW_DAYS=30
